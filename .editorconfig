# http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 80

[*.{md,mdx}]
trim_trailing_whitespace = false

[*.cs]
indent_size = 4
max_line_length = 120

[*.{csproj,fsproj,props,targets}]
indent_size = 2
