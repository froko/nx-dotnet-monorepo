{
  "name": "nx-dotnet-monorepo",
  "version": "0.0.1",
  "description": ".NET/JS Monorepo starter project with Nx",
  "author": "Patrick Ineichen",
  "repository": {
    "type": "git",
    "url": "https://github.com/froko/nx-dotnet-monorepo.git"
  },
  "license": "MIT",
  "scripts": {
    "format": "prettier . --write && nx run-many -t format --parallel",
    "affected": "nx affected -t lint,build,test",
    "all": "nx run-many -t lint,build,test",
    "lint": "nx run-many -t lint --parallel",
    "build": "nx run-many -t build --parallel",
    "test": "nx run-many -t test",
    "restore": "nx run-many -t restore",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@froko/prettier-config": "^3.1.0",
    "@nx/dotnet": "22.7.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "nx": "22.7.5"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
